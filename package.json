{
  "name": "arome-erp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist:exe": "vite build && electron-builder --win"
  },
  "dependencies": {
    "lucide-react": "0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "uz.dubai.parfumery.erp",
    "productName": "DUBAI Parfumery ERP",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
